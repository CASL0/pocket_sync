<?xml version="1.0" encoding="utf-8"?>
<!--
  cloud-backup と device-transfer の両方をすべて除外する。
  AWS 認証情報など端末ローカルのシークレットを Google アカウントの
  クラウドバックアップ・新端末への直接転送のいずれからも漏らさない
  ためのポリシー（Android 12+）。allowBackup="false" と併用する
  ことで API レベル横断で同等の効果を得る（ADR-0007 / security.md）。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
